{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and preferences.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "JPY"] },
        "timezone": { "type": "string" },
        "riskPerTrade": { "type": "number", "description": "Risk percentage per trade." },
        "dailyProfitTarget": { "type": "number" },
        "weeklyProfitTarget": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["displayName", "email"]
    },
    "Trade": {
      "title": "Trade Entry",
      "description": "A single trade entry.",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "direction": { "type": "string", "enum": ["long", "short"] },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "stopLoss": { "type": "number" },
        "targetPrice": { "type": "number" },
        "lots": { "type": "number" },
        "contractSize": { "type": "number" },
        "fees": { "type": "number" },
        "setup": { "type": "string" },
        "planFollowed": { "type": "boolean" },
        "mentalState": { "type": "string" },
        "keyLesson": { "type": "string" },
        "notes": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "screenshots": { "type": "array", "items": { "type": "string" } },
        "entryTime": { "type": "string", "format": "date-time" },
        "exitTime": { "type": "string", "format": "date-time" },
        "pnl": { "type": "number" },
        "roi": { "type": "number" },
        "riskReward": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["symbol", "direction", "entryPrice", "lots", "entryTime", "uid"]
    },
    "DailyJournal": {
      "title": "Daily Journal",
      "description": "Daily reflections and plans.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "plan": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["date", "content", "uid"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Trading goals and targets.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "target": { "type": "number" },
        "current": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "uid": { "type": "string" }
      },
      "required": ["type", "target", "startDate", "endDate", "uid"]
    },
    "SubscriptionPlan": {
      "title": "Subscription Plan",
      "description": "Available subscription plans.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "durationDays": { "type": "integer" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "durationDays", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A subscription purchase order.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "planId", "amount", "status", "createdAt"]
    },
    "FriendRequest": {
      "title": "Friend Request",
      "description": "A request to connect with another user.",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" },
        "toUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toUid", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A private message between friends.",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "content": { "type": "string" },
        "tradeId": { "type": "string", "description": "Optional ID of a shared trade." },
        "tradeOwnerUid": { "type": "string", "description": "UID of the trade owner." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUid", "toUid", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "User's trade entries."
    },
    "/users/{userId}/journals/{journalId}": {
      "schema": "DailyJournal",
      "description": "User's daily journal entries."
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User's trading goals."
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" }, "displayName": { "type": "string" }, "addedAt": { "type": "string", "format": "date-time" } } },
      "description": "User's friends list."
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Global friend requests."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Private messages."
    },
    "/plans/{planId}": {
      "schema": "SubscriptionPlan",
      "description": "Global subscription plans."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Subscription orders."
    }
  }
}
